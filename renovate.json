{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "timezone": "UTC",
  "packageRules": [
    {
      "description": "Group all non-security dependency updates weekly with minimum release age",
      "matchPackageNames": ["*"],
      "groupName": "all non-security dependencies",
      "minimumReleaseAge": "4 days",
      "schedule": ["on monday"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["every day"]
  }
}
